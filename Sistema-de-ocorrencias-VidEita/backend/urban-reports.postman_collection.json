{
  "info": {
    "name": "Urban Reports API",
    "_postman_id": "urban-reports-collection",
    "description": "Coleção de testes para a API de Ocorrência urbanas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "2. Cadastrar usuário",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const res = pm.response.json();",
            "if (res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "}"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"senha\": \"senha123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] }
      }
    },
    {
      "name": "3. Login",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const res = pm.response.json();",
            "if (res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "}"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"joao@email.com\",\n  \"senha\": \"senha123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users","login"] }
      }
    },
    {
      "name": "4. Ver perfil",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/users/profile", "host": ["{{baseUrl}}"], "path": ["users","profile"] }
      }
    },
    {
      "name": "5. Criar denúncia (sem imagem)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Buraco grande na Rua das Flores\",\n  \"descricao\": \"Buraco de aproximadamente 1 metro na pista, risco de acidente\",\n  \"categoria\": \"buraco\",\n  \"latitude\": -27.5969,\n  \"longitude\": -51.1442\n}"
        },
        "url": { "raw": "{{baseUrl}}/reports", "host": ["{{baseUrl}}"], "path": ["reports"] }
      }
    },
    {
      "name": "6. Listar todas as Ocorrência",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/reports?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["reports"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "status", "value": "pendente", "disabled": true },
            { "key": "categoria", "value": "buraco", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "7. Buscar Ocorrência próximas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/reports/nearby?lat=-27.5969&lng=-51.1442&raio=3",
          "host": ["{{baseUrl}}"],
          "path": ["reports","nearby"],
          "query": [
            { "key": "lat", "value": "-27.5969" },
            { "key": "lng", "value": "-51.1442" },
            { "key": "raio", "value": "3" }
          ]
        }
      }
    },
    {
      "name": "8. Atualizar status (admin)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"em_analise\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/reports/ID_DA_DENUNCIA/status", "host": ["{{baseUrl}}"], "path": ["reports","ID_DA_DENUNCIA","status"] }
      }
    },
    {
      "name": "9. Deletar denúncia",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/reports/ID_DA_DENUNCIA", "host": ["{{baseUrl}}"], "path": ["reports","ID_DA_DENUNCIA"] }
      }
    }
  ]
}
